default_platform(:ios)

def creatorai_api_key
  key_id = ENV["ASC_API_KEY_ID"] || "W4X38MD47K"
  issuer_id = ENV["ASC_API_ISSUER_ID"] || "bb537e37-2588-4655-bdd7-1c74901e580b"
  key_filepath = ENV["ASC_API_KEY_PATH"] || "fastlane/AuthKey_W4X38MD47K.p8"

  params = {
    key_id: key_id,
    key_filepath: key_filepath
  }
  params[:issuer_id] = issuer_id unless issuer_id.to_s.strip.empty?

  app_store_connect_api_key(**params)
end

platform :ios do
  desc "Diagnostic lane to list ALL existing localizations"
  lane :list_localizations_all do
    api_key = creatorai_api_key

    app = Spaceship::ConnectAPI::App.find("com.theholylabs.creator")
    version = app.get_edit_app_store_version
    
    if version
      UI.message("--- Version: #{version.version_string} (#{version.app_store_state}) ---")
      locs = version.get_app_store_version_localizations
      all_locales = locs.map(&:locale)
      UI.message("--- Found #{all_locales.count} Localizations: #{all_locales.join(', ')} ---")
    else
      UI.user_error!("No edit version found for this app.")
    end
  end

  desc "Upload screenshots and metadata (all languages) to App Store Connect"
  lane :upload_aso do
    api_key = creatorai_api_key

    app = Spaceship::ConnectAPI::App.find("com.theholylabs.creator")
    version = app.get_edit_app_store_version(includes: "appStoreVersionLocalizations")
    available = version.get_app_store_version_localizations.map(&:locale)
    UI.message("Available iOS locales: #{available.join(', ')}")

    src = File.expand_path("metadata", __dir__)
    tmp_metadata = File.join(Dir.tmpdir, "fastlane_ios_metadata")
    FileUtils.rm_rf(tmp_metadata)
    FileUtils.mkdir_p(tmp_metadata)

    Dir.children(src).each do |locale|
      locale_path = File.join(src, locale)
      next unless File.directory?(locale_path)
      if available.include?(locale)
        FileUtils.cp_r(locale_path, File.join(tmp_metadata, locale))
      else
        UI.message("Skipping #{locale} (not on iOS)")
      end
    end

    deliver(
      api_key: api_key,
      skip_binary_upload: true,
      skip_app_version_update: false,
      force: true,
      overwrite_screenshots: true,
      screenshots_path: "./fastlane/screenshots",
      metadata_path: tmp_metadata,
      precheck_include_in_app_purchases: false,
      run_precheck_before_submit: false,
      ignore_language_directory_validation: true,
      submit_for_review: false,
      automatic_release: true
    )

    FileUtils.rm_rf(tmp_metadata)
  end

  desc "Add missing locales via Spaceship then push metadata"
  lane :add_locales_and_upload do
    api_key = creatorai_api_key

    target_locales = %w[
      ar-SA de-DE en-CA en-GB en-US es-ES es-MX fr-FR id it ja ko nl-NL pt-BR pt-PT ru th tr vi zh-Hans zh-Hant
    ]

    app = Spaceship::ConnectAPI::App.find("com.theholylabs.creator")
    version = app.get_edit_app_store_version(includes: "appStoreVersionLocalizations")
    existing = version.get_app_store_version_localizations.map(&:locale)
    UI.message("Existing locales: #{existing.join(', ')}")

    names = {
      "en-US" => "CreatorAI - AI Video Maker",
      "en-GB" => "CreatorAI - AI Video Maker",
      "en-CA" => "CreatorAI",
      "de-DE" => "CreatorAI - KI Video Maker",
      "fr-FR" => "CreatorAI - Vidéo IA",
      "es-ES" => "CreatorAI - Video con IA",
      "es-MX" => "CreatorAI - Video con IA",
      "pt-BR" => "CreatorAI - Vídeo com IA",
      "pt-PT" => "CreatorAI - Vídeo com IA",
      "ar-SA" => "CreatorAI",
      "ja"    => "CreatorAI - AI動画メーカー",
      "ko"    => "CreatorAI - AI 영상 메이커",
      "zh-Hans" => "CreatorAI - AI视频创作",
      "zh-Hant" => "CreatorAI - AI影片創作",
      "it"    => "CreatorAI - Video con IA",
      "nl-NL" => "CreatorAI - AI Videogenerator",
      "ru"    => "CreatorAI - ИИ видео",
      "tr"    => "CreatorAI - AI Video Yapıcı",
      "id"    => "CreatorAI - Pembuat Video AI",
      "th"    => "CreatorAI - AI วิดีโอ",
      "vi"    => "CreatorAI - Tạo Video AI",
    }

    (target_locales - existing).each do |locale|
      name = names[locale] || "CreatorAI"
      UI.message("Adding locale #{locale} with name '#{name}'")
      begin
        version.create_app_store_version_localization(attributes: { locale: locale, name: name })
        UI.success("Added #{locale}")
      rescue => e
        UI.error("Failed to add #{locale}: #{e.message}")
      end
    end

    deliver(
      api_key: api_key,
      skip_binary_upload: true,
      skip_app_version_update: false,
      force: true,
      overwrite_screenshots: true,
      screenshots_path: "./fastlane/screenshots",
      metadata_path: "./fastlane/metadata",
      precheck_include_in_app_purchases: false,
      run_precheck_before_submit: false,
      ignore_language_directory_validation: true,
      submit_for_review: true,
      automatic_release: true
    )
  end
end

platform :mac do
  desc "Upload macOS metadata to App Store Connect (all languages)"
  lane :upload_aso do
    api_key = creatorai_api_key

    src = File.expand_path("metadata", __dir__)
    app = Spaceship::ConnectAPI::App.find("com.theholylabs.creator")
    version = app.get_edit_app_store_version(platform: Spaceship::ConnectAPI::Platform::MAC_OS, includes: "appStoreVersionLocalizations")
    available = version.get_app_store_version_localizations.map(&:locale)
    UI.message("Available macOS locales: #{available.join(', ')}")

    tmp_metadata = File.join(Dir.tmpdir, "fastlane_macos_metadata")
    FileUtils.rm_rf(tmp_metadata)
    FileUtils.mkdir_p(tmp_metadata)

    Dir.children(src).each do |locale|
      locale_path = File.join(src, locale)
      next unless File.directory?(locale_path)
      if available.include?(locale)
        FileUtils.cp_r(locale_path, File.join(tmp_metadata, locale))
        UI.message("Copied #{locale} (#{Dir.children(File.join(tmp_metadata, locale)).join(', ')})")
      else
        UI.message("Skipping #{locale} (not on macOS)")
      end
    end

    deliver(
      api_key: api_key,
      platform: "osx",
      skip_binary_upload: true,
      skip_app_version_update: false,
      force: true,
      metadata_path: tmp_metadata,
      precheck_include_in_app_purchases: false,
      run_precheck_before_submit: false,
      ignore_language_directory_validation: true,
      submit_for_review: false,
      automatic_release: true,
      skip_screenshots: true
    )

    FileUtils.rm_rf(tmp_metadata)
  end

  desc "Add missing locales and upload macOS metadata"
  lane :add_locales_and_upload do
    api_key = creatorai_api_key

    # en-US and en-GB excluded: Apple blocks adding them because the app name is taken on macOS
    target_locales = %w[
      ar-SA de-DE en-CA es-ES es-MX fr-FR id it ja ko nl-NL pt-BR pt-PT ru th tr vi zh-Hans zh-Hant
    ]

    app = Spaceship::ConnectAPI::App.find("com.theholylabs.creator")
    version = app.get_edit_app_store_version(platform: Spaceship::ConnectAPI::Platform::MAC_OS, includes: "appStoreVersionLocalizations")
    existing = version.get_app_store_version_localizations.map(&:locale)
    UI.message("Existing macOS locales: #{existing.join(', ')}")

    names = {
      "en-CA" => "CreatorAI",
      "de-DE" => "CreatorAI - KI Video Maker",
      "fr-FR" => "CreatorAI - Vidéo IA",
      "es-ES" => "CreatorAI - Video con IA",
      "es-MX" => "CreatorAI - Video con IA",
      "pt-BR" => "CreatorAI - Vídeo com IA",
      "pt-PT" => "CreatorAI - Vídeo com IA",
      "ar-SA" => "CreatorAI",
      "ja"    => "CreatorAI - AI動画メーカー",
      "ko"    => "CreatorAI - AI 영상 메이커",
      "zh-Hans" => "CreatorAI - AI视频创作",
      "zh-Hant" => "CreatorAI - AI影片創作",
      "it"    => "CreatorAI - Video con IA",
      "nl-NL" => "CreatorAI - AI Videogenerator",
      "ru"    => "CreatorAI - ИИ видео",
      "tr"    => "CreatorAI - AI Video Yapıcı",
      "id"    => "CreatorAI - Pembuat Video AI",
      "th"    => "CreatorAI - AI วิดีโอ",
      "vi"    => "CreatorAI - Tạo Video AI",
    }

    (target_locales - existing).each do |locale|
      UI.message("Adding macOS locale #{locale}")
      begin
        version.create_app_store_version_localization(attributes: { locale: locale })
        UI.success("Added #{locale}")
      rescue => e
        UI.error("Failed to add #{locale}: #{e.message}")
      end
    end

    # Re-fetch after adding locales
    version = app.get_edit_app_store_version(platform: Spaceship::ConnectAPI::Platform::MAC_OS, includes: "appStoreVersionLocalizations")
    available = version.get_app_store_version_localizations.map(&:locale)

    src = File.expand_path("metadata", __dir__)
    tmp_metadata = File.join(Dir.tmpdir, "fastlane_macos_metadata")
    FileUtils.rm_rf(tmp_metadata)
    FileUtils.mkdir_p(tmp_metadata)

    Dir.children(src).each do |locale|
      locale_path = File.join(src, locale)
      next unless File.directory?(locale_path)
      if available.include?(locale)
        FileUtils.cp_r(locale_path, File.join(tmp_metadata, locale))
      else
        UI.message("Skipping #{locale} (not on macOS)")
      end
    end

    deliver(
      api_key: api_key,
      platform: "osx",
      skip_binary_upload: true,
      skip_app_version_update: false,
      force: true,
      metadata_path: tmp_metadata,
      precheck_include_in_app_purchases: false,
      run_precheck_before_submit: false,
      ignore_language_directory_validation: true,
      submit_for_review: false,
      automatic_release: true,
      skip_screenshots: true
    )

    FileUtils.rm_rf(tmp_metadata)
  end
end
