# Server
PORT=3001
BASE_URL=https://creator-api.holylabs.net

# Database (Neon or Postgres)
DATABASE_URL=postgres://user:pass@host:5432/creator_ai

# OpenRouter (AI script generation)
OPENROUTER_API_KEY=sk-or-v1-xxx

# Pexels (stock footage)
PEXELS_API_KEY=xxx

# Uploadcare (file storage)
UPLOADCARE_PUBLIC_KEY=xxx
UPLOADCARE_SECRET_KEY=xxx

# Auth
JWT_SECRET=your-secret-here

# ffmpeg path (usually auto-detected)
FFMPEG_PATH=/usr/bin/ffmpeg
