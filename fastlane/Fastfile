default_platform(:ios)

def creatorai_api_key
  app_store_connect_api_key(
    key_id: "TR5F2GR4AJ",
    issuer_id: "5a3c4e24-d77f-43a3-8f73-b6c65aeb6a9c",
    key_filepath: "store/fastlane/AuthKey_TR5F2GR4AJ.p8"
  )
end

def upload_creatorai_metadata(platform_name:, platform_value:)
  creatorai_api_key

  app = Spaceship::ConnectAPI::App.find("com.theholylabs.creator")
  version = app.get_edit_app_store_version(
    platform: platform_value,
    includes: "appStoreVersionLocalizations"
  )

  unless version
    UI.user_error!("No editable #{platform_name} app store version found. Create/open version 3.3 in App Store Connect first.")
  end

  localizations = version.get_app_store_version_localizations
  UI.message("Found #{localizations.count} #{platform_name} localizations: #{localizations.map(&:locale).join(', ')}")

  metadata_path = File.expand_path("../fastlane/metadata", __dir__)
  updated = 0
  skipped = 0

  localizations.each do |loc|
    locale_dir = File.join(metadata_path, loc.locale)
    unless File.directory?(locale_dir)
      UI.important("Skipping #{loc.locale}: no metadata folder")
      skipped += 1
      next
    end

    release_file = File.join(locale_dir, "release_notes.txt")
    promo_file = File.join(locale_dir, "promotional_text.txt")

    attrs = {}
    attrs[:whatsNew] = File.read(release_file).strip if File.exist?(release_file)
    attrs[:promotionalText] = File.read(promo_file).strip if File.exist?(promo_file)

    if attrs.empty?
      UI.important("Skipping #{loc.locale}: no release notes or promotional text")
      skipped += 1
      next
    end

    begin
      loc.update(attributes: attrs)
      UI.success("Updated #{platform_name} #{loc.locale}")
      updated += 1
    rescue => e
      UI.error("Failed to update #{platform_name} #{loc.locale}: #{e.message}")
    end
  end

  UI.message("Done #{platform_name}: updated #{updated}, skipped #{skipped}")
end

platform :ios do
  desc "Upload iOS release notes + promotional text to existing localizations"
  lane :upload_metadata do
    upload_creatorai_metadata(platform_name: "iOS", platform_value: "IOS")
  end
end

platform :mac do
  desc "Upload macOS release notes + promotional text to existing localizations"
  lane :upload_metadata do
    upload_creatorai_metadata(platform_name: "macOS", platform_value: "MAC_OS")
  end
end

desc "Upload iOS and macOS release notes + promotional text"
lane :upload_all_metadata do
  upload_creatorai_metadata(platform_name: "iOS", platform_value: "IOS")
  upload_creatorai_metadata(platform_name: "macOS", platform_value: "MAC_OS")
end
